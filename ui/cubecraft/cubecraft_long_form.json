{
    "namespace": "cubecraft_long_form",
    "long_form_with_header": {
        "type": "stack_panel",
        "orientation": "vertical",
        "size": [
            "100%",
            200
        ],
        "max_size": [
            372,
            200
        ],
        "controls": [
            {
                "header@cubecraft_common.header_panel": {
                    "size": [
                        "100% - 4px",
                        20
                    ],
                    "max_size": [
                        367,
                        20
                    ]
                }
            },
            {
                "content@cubecraft_long_form.long_form": {}
            }
        ]
    },
    "long_form": {
        "type": "stack_panel",
        "size": [
            "100% - 8px",
            "100%"
        ],
        "orientation": "horizontal",
        "controls": [
            {
                "button_and_text_panel": {
                    "type": "panel",
                    "size": [
                        "100% - 2px",
                        "100%"
                    ],
                    "controls": [
                        {
                            "scrolling_panel@cubecraft_scroll.scrolling_panel": {
                                "anchor_from": "center",
                                "anchor_to": "center",
                                "size": [
                                    "100% - 20px",
                                    "100%"
                                ],
                                "$show_background": false,
                                "$scroll_bar_side": "right",
                                "$scrolling_content": "cubecraft_long_form.long_form_scrolling_content",
                                "$scroll_size": [
                                    6,
                                    "100%"
                                ],
                                "$scrolling_pane_size": [
                                    "100% + 20px",
                                    "100%"
                                ],
                                "$scrolling_pane_offset": [
                                    10,
                                    0
                                ],
                                "$scroll_bar_right_padding_size": [
                                    6,
                                    0
                                ]
                            }
                        },
                        {
                            "rounded_box": {
                                "type": "image",
                                "texture": "textures/ui/dialog_background_opaque",
                                "anchor_to": "center",
                                "anchor_from": "center",
                                "offset": [ 1, 0 ],
                                "size": [ "100% + 10px", "100% + 12px" ],
                                "alpha": 1
                            }
                        }
                    ]
                }
            }
        ]
    },
    "long_form_scrolling_content": {
        "type": "stack_panel",
        "size": [
            "100% - 4px",
            "100%c"
        ],
        "orientation": "vertical",
        "anchor_from": "top_left",
        "anchor_to": "top_left",
        "controls": [
            {
                "padding_0": {
                    "type": "panel",
                    "size": [
                        "100%",
                        2
                    ]
                }
            },
            {
                "content_text_panel@cubecraft_common.rounded_textbox_blue": {
                    "type": "panel",
                    "size": [
                        "100%",
                        "100%cm + 4px"
                    ],
                    "$content_text": "#form_content_text",
                    "$additional_label_bindings": "@cubecraft_common.nested_form_details_bindings",
                    "bindings": [
                        {
                            "binding_type": "view",
                            "source_control_name": "form_details",
                            "source_property_name": "#form_content_text",
                            "target_property_name": "#form_content_text"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "(not (#form_content_text = ''))",
                            "target_property_name": "#visible"
                        }
                    ]
                }
            },
            {
                "padding_1": {
                    "type": "panel",
                    "size": [
                        "100%",
                        2
                    ]
                }
            },
            {
                "wrapping_panel": {
                    "type": "panel",
                    "size": [
                        "100%",
                        "100%c"
                    ],
                    "controls": [
                        {
                            "long_form_dynamic_buttons_panel@cubecraft_long_form.long_form_dynamic_buttons_panel": {}
                        }
                    ]
                }
            },
            {
                "padding_2": {
                    "type": "panel",
                    "size": [
                        "100%",
                        2
                    ]
                }
            }
        ]
    },
    "long_form_dynamic_buttons_panel": {
        "type": "stack_panel",
        "size": [
            "100% - 6px",
            "100%c"
        ],
        "orientation": "vertical",
        "anchor_from": "top_middle",
        "anchor_to": "top_middle",
        "factory": {
            "name": "buttons",
            "control_name": "cubecraft_long_form.dynamic_button"
        },
        "collection_name": "form_buttons",
        "bindings": [
            {
                "binding_condition": "once",
                "binding_name": "#form_button_length",
                "binding_name_override": "#collection_length"
            }
        ]
    },
    "dynamic_button": {
        "type": "stack_panel",
        "size": [
            "100%",
            34
        ],
        "orientation": "horizontal",
        "controls": [
            {
                "image_panel@cubecraft_long_form.image_panel": {}
            },
            {
                "form_button@cubecraft_buttons.light_text_button": {
                    "$pressed_button_name": "button.form_button_click",
                    "anchor_from": "top_left",
                    "anchor_to": "top_left",
                    "size": [
                        "fill",
                        32
                    ],
                    "$focus_id": "form_button_long",
                    "$default_focus_precedence": 10,
                    "$button_text": "#form_button_text",
                    "$button_text_binding_type": "collection",
                    "$button_text_grid_collection_name": "form_buttons",
                    "$button_text_max_size": [
                        "100%",
                        20
                    ],
                    "bindings": [
                        {
                            "binding_type": "collection_details",
                            "binding_collection_name": "form_buttons"
                        }
                    ]
                }
            }
        ]
    },
    "image_panel": {
        "type": "panel",
        "size": [
            36,
            "100%c"
        ],
        "bindings": [
            {
                "binding_type": "view",
                "source_control_name": "image",
                "resolve_sibling_scope": true,
                "source_property_name": "(not (#texture = ''))",
                "target_property_name": "#visible"
            }
        ],
        "controls": [
            {
                "image": {
                    "type": "image",
                    "layer": 2,
                    "size": [
                        32,
                        32
                    ],
                    "bindings": [
                        {
                            "binding_name": "#form_button_texture",
                            "binding_name_override": "#texture",
                            "binding_type": "collection",
                            "binding_collection_name": "form_buttons"
                        },
                        {
                            "binding_name": "#form_button_texture_file_system",
                            "binding_name_override": "#texture_file_system",
                            "binding_type": "collection",
                            "binding_collection_name": "form_buttons"
                        },
                        {
                            "binding_type": "view",
                            "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                            "target_property_name": "#visible"
                        }
                    ]
                }
            },
            {
                "progress@progress.progress_loading_bars": {
                    "size": [
                        30,
                        4
                    ],
                    "offset": [
                        -2,
                        16
                    ],
                    "bindings": [
                        {
                            "binding_type": "view",
                            "source_control_name": "image",
                            "resolve_sibling_scope": true,
                            "source_property_name": "(#texture = 'loading')",
                            "target_property_name": "#visible"
                        }
                    ]
                }
            }
        ]
    }
}
