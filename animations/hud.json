{
  "format_version": "1.8.0",
  "animations": {
    "animation.hud_use_item_progress": {
      "loop": true,
      "bones": {
        "hud_eat_indicator": {
          "position": [ -8, "-895 + (1.2 * (1 - math.pow(5, -10 * ((30 - query.main_hand_item_use_duration) / 30))))", 0 ],
          "scale": [ "q.is_using_item ? (1 - math.clamp(query.main_hand_item_use_duration / 30, 0, 1)) * (query.is_swimming ? 0 : 2) : 0", 1, 1 ]
        },
        "hud_eat_indicator_full": {
          "position": [ -8, "-895 + (1.2 * (1 - math.pow(5, -10 * ((30 - query.main_hand_item_use_duration) / 30))))", 0 ],
          "scale": [ "query.is_swimming ? 0 : 2", 1, 1 ]
        }
      }
    }
  }
}
