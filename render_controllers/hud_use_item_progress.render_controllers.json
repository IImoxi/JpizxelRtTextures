{
    "format_version": "1.16.0",
    "render_controllers": {
        "controller.render.hud_eat_indicator": {
            "geometry": "Geometry.hud_eat_indicator",
            "materials": [ { "*": "Material.default" } ],
            "textures": [ "texture.eat_indicator" ],
            "is_hurt_color": {},
            "on_fire_color": {},
            "light_color_multiplier": 1.3,
            "ignore_lighting": true,
            "overlay_color": {
                "r": "0.0",
                "g": "1.0",
                "b": "0.0",
                "a": "query.item_in_use_duration * 0.05 >= (query.get_equipped_item_name == 'bow' ? 20 : query.main_hand_item_max_duration - 1) ? 0.75 : 0.0"
            }
        }
    }
}
