				"material": "particles_add",
				"texture": "textures/particle/bloom_offset"
			}
		},
		"events": {
			"stage2": {
				"particle_effect": {
					"effect": "ii:magic_stage2",
					"type": "emitter"
				}
			}
		},
		"components": {
