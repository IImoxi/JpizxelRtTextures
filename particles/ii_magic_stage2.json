					"texture_width": 32,
					"texture_height": 16,
					"uv": [32, 0],
					"uv_size": [-32, 16]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": [0, 0.6, 0.3, "math.clamp(1 - (v.particle_age * 4),0 , 1)"]
