{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "minecraft:player",
			"particle_effects": {
				"indicator_immunity": "ii:crown"
			},
			"textures": {
				"default": "textures/entity/steve",
				"cape": "textures/entity/cape_invisible",
				"eat_indicator": "textures/gui/eat_indicator"
			},
			"geometry": {
				"default": "geometry.humanoid.custom",
				"cape": "geometry.cape",
				"hud_eat_indicator": "geometry.hud_eat_indicator"
			},
			"scripts": {
				"scale": "0.9",
				"animate": [
					"root",
					"this",
					{ "hud_utility": "variable.this" },
					{ "hud_movement_speed_clock": "variable.this" },
					{ "third_person_utility": "variable.first_person_rotation_factor" }
				]
			},
			"animations": {
			"root": "controller.animation.player.root",
			"this": "controller.animation.this",
			"hud_utility": "controller.animation.hud_utility",
			"third_person_utility": "controller.animation.third_person_utility",
			"health": "animation.health",
			"offhand": "animation.offhand",
			"offhand_shield": "animation.offhand_shield",
			"armor_root": "animation.armor_root",
			"hud_armor_root": "animation.hud_armor_root",
			"hud_offhand": "animation.hud_offhand",
			"hud_offhand_slot": "animation.hud_offhand_slot",
			"hitbox": "animation.hitbox",
			"hud_use_item_progress": "animation.hud_use_item_progress",
			"bow_root": "animation.bow_root",
			"hud_movement_speed": "animation.hud_movement_speed",
			"hud_movement_speed_clock": "controller.animation.hud_movement_speed_clock",
			"chunk_border": "animation.chunk_border",
			"base_controller": "controller.animation.player.base",
			"hudplayer":  "controller.animation.player.hudplayer",
			"humanoid_base_pose": "animation.humanoid.base_pose",
			"look_at_target": "controller.animation.humanoid.look_at_target",
			"look_at_target_ui": "animation.player.look_at_target.ui",
			"look_at_target_default": "animation.humanoid.look_at_target.default",
			"look_at_target_gliding": "animation.humanoid.look_at_target.gliding",
			"look_at_target_swimming": "animation.humanoid.look_at_target.swimming",
			"look_at_target_inverted": "animation.player.look_at_target.inverted",
			"cape": "animation.player.cape",
			"move.arms": "animation.player.move.arms",
			"move.legs": "animation.player.move.legs",
			"swimming": "animation.player.swim",
			"swimming.legs": "animation.player.swim.legs",
			"riding.arms": "animation.player.riding.arms",
			"riding.legs": "animation.player.riding.legs",
			"holding": "animation.player.holding",
			"brandish_spear": "animation.humanoid.brandish_spear",
			"charging": "animation.humanoid.charging",
			"attack.positions": "animation.player.attack.positions",
			"attack.rotations": "animation.player.attack.rotations",
			"sneaking": "animation.player.sneaking",
			"bob": "animation.player.bob",
			"damage_nearby_mobs": "animation.humanoid.damage_nearby_mobs",
			"fishing_rod": "animation.humanoid.fishing_rod",
			"use_item_progress": "animation.humanoid.use_item_progress",
			"skeleton_attack": "animation.skeleton.attack",
			"sleeping": "animation.player.sleeping",
			"first_person_base_pose": "animation.player.first_person.base_pose",
			"first_person_empty_hand": "animation.player.first_person.empty_hand",
			"first_person_swap_item": "animation.player.first_person.swap_item",
			"first_person_attack_controller": "controller.animation.player.first_person_attack",
			"first_person_attack_rotation": "animation.player.first_person.attack_rotation",
			"first_person_vr_attack_rotation": "animation.player.first_person.vr_attack_rotation",
			"first_person_map_controller": "controller.animation.player.first_person_map",
			"first_person_map_hold": "animation.player.first_person.map_hold",
			"first_person_map_hold_attack": "animation.player.first_person.map_hold_attack",
			"first_person_map_hold_off_hand": "animation.player.first_person.map_hold_off_hand",
			"first_person_map_hold_main_hand": "animation.player.first_person.map_hold_main_hand",
			"first_person_crossbow_equipped": "animation.player.first_person.crossbow_equipped",
			"third_person_crossbow_equipped": "animation.player.crossbow_equipped",
			"third_person_bow_equipped": "animation.player.bow_equipped",
			"crossbow_hold": "animation.player.crossbow_hold",
			"crossbow_controller": "controller.animation.player.crossbow",
			"shield_block_main_hand": "animation.player.shield_block_main_hand",
			"shield_block_off_hand": "animation.player.shield_block_off_hand",
			"blink": "controller.animation.persona.blink"
			},
			"render_controllers": [
				{ "controller.render.player.first_person": "variable.is_first_person" },
				{ "controller.render.player.third_person": "!variable.is_first_person && !variable.map_face_icon" },
				{ "controller.render.player.map": "variable.map_face_icon" },
				//uncomment this render controller to activate your custom cape
				//{ "controller.render.player.cape": "!variable.is_first_person && !variable.map_face_icon && variable.this" },
				{ "controller.render.hitbox": "variable.third_person_render" },
				{ "controller.render.chunk_border": "variable.third_person_render && variable.this && query.is_item_equipped(1) && query.get_equipped_item_name(1) != 'shield'" },
				{ "controller.render.bow_progress": "variable.third_person_render && query.get_equipped_item_name == 'bow'" },
				{ "controller.render.health_ones": "variable.third_person_render" },
				{ "controller.render.health_tens": "variable.third_person_render && query.health >= 10" },
				{ "controller.render.offhand": "variable.third_person_render && query.is_item_equipped(1)" },
				{ "controller.render.helmet": "variable.third_person_render && query.has_armor_slot(0)" },
				{ "controller.render.chestplate": "variable.third_person_render && query.has_armor_slot(1)" },
				{ "controller.render.leggings": "variable.third_person_render && query.has_armor_slot(2)" },
				{ "controller.render.boots": "variable.third_person_render && query.has_armor_slot(3)" },
				{ "controller.render.hud_helmet": "query.has_armor_slot(0) && variable.hud_render2" },
				{ "controller.render.hud_chestplate": "query.has_armor_slot(1) && variable.hud_render2" },
				{ "controller.render.hud_leggings": "query.has_armor_slot(2) && variable.hud_render2" },
				{ "controller.render.hud_boots": "query.has_armor_slot(3) && variable.hud_render2" },
				//placing the offhand render controller above the offhand slot render controller allows it to render the item on top
				{ "controller.render.hud_offhand": "query.is_item_equipped(1) && variable.hud_render2" },
				{ "controller.render.hud_offhand_slot": "query.is_item_equipped(1) && variable.hud_render2" },
				{ "controller.render.hud_use_item_progress_ones": "variable.use_item_type && variable.hud_render2" },
				{ "controller.render.hud_use_item_progress_tens": "variable.use_item_type && variable.hud_render2 && variable.item_use_normalized <= 0.9" },
				{ "controller.render.hud_eat_indicator": "variable.use_item_type" },
				{ "controller.render.hud_movement_speed_tens": "variable.hud_render2 && query.ground_speed >= 10.0" },
				{ "controller.render.hud_movement_speed_ones": "variable.hud_render2" },
				{ "controller.render.hud_movement_speed_ones_decimal": "variable.hud_render2" },
				{ "controller.render.hud_movement_speed_tens_decimal": "variable.hud_render2" },
				{ "controller.render.hud_movement_speed_background": "variable.hud_render2" }
			],
			"enable_attachables": true
		}
	}
}
