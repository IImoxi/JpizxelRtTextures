{
	"format_version": "1.16.0",
	"minecraft:client_entity": {
		"description": {
			//"min_engine_version": "1.12.0",
			"identifier": "minecraft:player",
			"particle_effects": {
				"indicator_immunity": "ii:crown"
			},
			"materials": {
				"default": "entity_alphatest",
				"cape": "entity_alphatest",
				"animated": "player_animated",
				"spectator": "player_spectator"
			},
			"textures": {
				"default": "textures/entity/steve",
				"cape": "textures/entity/cape_invisible",
				"eat_indicator": "textures/gui/eat_indicator"
			},
			"geometry": {
				"default": "geometry.humanoid.custom",
				"cape": "geometry.cape",
				"hud_eat_indicator": "geometry.hud_eat_indicator"
			},
			"scripts": {
				"scale": "0.89",
				"initialize": [
					"variable.is_holding_right = 0.0;",
					"variable.is_blinking = 0.0;",
					"variable.last_blink_time = 0.0;",
					"variable.hand_bob = 0.0;",

					"v.should_render_hud = 0.0;",
					"v.should_render_hud_use_item_progress = 0.0;",
					"q.is_in_ui ? { v.should_render_hud = 0.0; };",
					"v.hud_use_item_progress_normalized = 1.0;"
				],
				"animate": [
					"root",
					"hud_utility"
				],
				"variables": {
					"variable.fp_melee_spear_use_attachable_rotation_z": "public",
					"variable.tp_melee_spear_use_attachable_rotation_z": "public",
					"variable.fp_melee_spear_attack_attachable_rotation_z": "public",
					"variable.tp_melee_spear_attack_attachable_position_z": "public",
					"variable.attack_time": "public",
					"variable.item_use_normalized": "public"
				}
			},
			"animations": {
				"root": "controller.animation.player.root",
				"base_controller": "controller.animation.player.base",
				"hudplayer": "controller.animation.player.hudplayer",
				"use_item_progress": "animation.humanoid.use_item_progress",

				"hud_utility": "controller.animation.hud_utility",
				"hud_use_item_progress": "animation.hud_use_item_progress"
			},
			"render_controllers": [
				// Vanilla //
				{ "controller.render.player.first_person_spectator": "variable.is_first_person && query.is_spectator" },
				{ "controller.render.player.third_person_spectator": "!variable.is_first_person && !variable.map_face_icon && query.is_spectator" },
				{ "controller.render.player.first_person": "variable.is_first_person" },
				{ "controller.render.player.third_person": "!variable.is_first_person && !variable.map_face_icon" },
				{ "controller.render.player.map": "variable.map_face_icon" },
				// Vanilla //

				{ "controller.render.hud_eat_indicator": "1.0" } //variable.use_item_type
			],
			"enable_attachables": true
		}
	}
}
